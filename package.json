{
  "name": "damsole-crm-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npx next dev",
    "build": "npx next build",
    "build:render": "cross-env NODE_OPTIONS=--max-old-space-size=400 npx next build",
    "start": "npx next start -p ${PORT:-3000}",
    "start:render": "if [ ! -d .next ]; then echo 'Build not found. Please run npm run build first.'; exit 1; fi && npx next start -p ${PORT:-3000}",
    "lint": "npx next lint"
  },
  "dependencies": {
    "autoprefixer": "^10.4.0",
    "framer-motion": "^11.18.2",
    "next": "^14.2.0",
    "postcss": "^8.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-icons": "^5.5.0",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^3.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "cross-env": "^10.1.0",
    "typescript": "^5.4.0"
  }
}
